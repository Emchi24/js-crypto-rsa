{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "../",
    "outDir": "./dist-benchmark",

    
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,         
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2020"],
    
    "types": ["node"]              
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  },
  "include": [
    "tests/**/*", "../src/convertStringToObject.ts", "../src/convertValueToBigintObject.ts", "../src/convertObjectToString.ts", 
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-benchmark"
  ]
}